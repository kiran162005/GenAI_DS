 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# AI Resume Screening System\n",
    "**LangChain + LangSmith | 100% Free**\n\n",
    "Pipeline: Resume → Extraction → Matching → Scoring → Explanation → Tracing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q langchain langchain-community langsmith transformers sentencepiece torch"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# FREE LangSmith key: sign up at smith.langchain.com -> Settings -> API Keys\n",
    "os.environ['LANGCHAIN_TRACING_V2'] = 'true'\n",
    "os.environ['LANGCHAIN_PROJECT']    = 'AI-Resume-Screener'\n",
    "os.environ["LANGCHAIN_API_KEY"] = "YOUR_LANGSMITH_API_KEY"\n",
    "\n",
    "print('LangSmith tracing enabled')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import pipeline as hf_pipeline\n",
    "from langchain_community.llms import HuggingFacePipeline\n",
    "from langchain.prompts import PromptTemplate\n",
    "from langchain_core.output_parsers import StrOutputParser\n",
    "import re\n",
    "\n",
    "print('Loading flan-t5-base... (downloads once ~250MB then cached)')\n",
    "hf_pipe = hf_pipeline('text2text-generation', model='google/flan-t5-base',\n",
    "                       max_new_tokens=80, do_sample=False)\n",
    "llm    = HuggingFacePipeline(pipeline=hf_pipe)\n",
    "parser = StrOutputParser()\n",
    "print('Model ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "JOB_DESCRIPTION    = 'Python, Machine Learning, Deep Learning. Experience: 2+ years. Tools: TensorFlow, PyTorch'\n",
    "REQUIRED_SKILLS    = ['python', 'machine learning', 'deep learning', 'tensorflow', 'pytorch']\n",
    "REQUIRED_YEARS     = 2\n",
    "\n",
    "RESUMES = [\n",
    "    {'name': 'Alice (Strong)',\n",
    "     'text': 'Python, Machine Learning, Deep Learning, NLP. 3 years Data Science. Tools: TensorFlow, PyTorch, Pandas.'},\n",
    "    {'name': 'Ben (Average)',\n",
    "     'text': 'Python, basic Machine Learning. 1 year experience. Tools: Pandas, Scikit-learn.'},\n",
    "    {'name': 'Carlos (Weak)',\n",
    "     'text': 'HTML, CSS. Fresher. No ML experience.'},\n",
    "]\n",
    "print('Data ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def step1_extract(text):\n",
    "    t = text.lower()\n",
    "    all_skills = ['python','sql','machine learning','deep learning','nlp',\n",
    "                  'tensorflow','pytorch','pandas','scikit-learn','html','css']\n",
    "    found = [s for s in all_skills if s in t]\n",
    "    m     = re.search(r'(\\d+)\\s+year', t)\n",
    "    years = int(m.group(1)) if m else 0\n",
    "    tools = [s for s in ['tensorflow','pytorch','pandas','scikit-learn'] if s in t]\n",
    "    return {'skills': found, 'experience_years': years, 'tools': tools}\n",
    "\n",
    "def step2_match(extracted):\n",
    "    matched = [s for s in REQUIRED_SKILLS if s in extracted['skills']]\n",
    "    missing = [s for s in REQUIRED_SKILLS if s not in extracted['skills']]\n",
    "    exp_ok  = extracted['experience_years'] >= REQUIRED_YEARS\n",
    "    pct     = len(matched) / len(REQUIRED_SKILLS)\n",
    "    overall = 'Strong' if pct >= 0.8 and exp_ok else ('Average' if pct >= 0.4 else 'Weak')\n",
    "    return {'matched': matched, 'missing': missing, 'exp_ok': exp_ok, 'overall': overall}\n",
    "\n",
    "def step3_score(extracted, match):\n",
    "    s = round((len(match['matched']) / len(REQUIRED_SKILLS)) * 40)\n",
    "    e = 25 if match['exp_ok'] else round((extracted['experience_years'] / REQUIRED_YEARS) * 25)\n",
    "    t = round((len([x for x in extracted['tools'] if x in ['tensorflow','pytorch']]) / 2) * 20)\n",
    "    return {'total': s+e+t+10, 'skill_pts': s, 'exp_pts': e, 'tool_pts': t}\n",
    "\n",
    "explain_prompt = PromptTemplate(\n",
    "    input_variables=['score', 'matched', 'missing', 'overall'],\n",
    "    template=('A candidate scored {score}/100 for a Data Science job. '\n",
    "              'They have: {matched}. They are missing: {missing}. '\n",
    "              'Overall match: {overall}. Should we hire them? Answer in one sentence.')\n",
    ")\n",
    "explain_chain = explain_prompt | llm | parser\n",
    "print('Pipeline steps ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_pipeline(candidate):\n",
    "    extracted   = step1_extract(candidate['text'])\n",
    "    match       = step2_match(extracted)\n",
    "    scores      = step3_score(extracted, match)\n",
    "    explanation = explain_chain.invoke({\n",
    "        'score':   scores['total'],\n",
    "        'matched': ', '.join(match['matched']) or 'none',\n",
    "        'missing': ', '.join(match['missing']) or 'none',\n",
    "        'overall': match['overall']\n",
    "    })\n",
    "    rec = 'HIRE' if scores['total'] >= 70 else ('CONSIDER' if scores['total'] >= 40 else 'REJECT')\n",
    "\n",
    "    print('=' * 50)\n",
    "    print('Candidate :', candidate['name'])\n",
    "    print('=' * 50)\n",
    "    print('STEP 1 - Skills :', extracted['skills'])\n",
    "    print('         Exp    :', extracted['experience_years'], 'years')\n",
    "    print('         Tools  :', extracted['tools'])\n",
    "    print('STEP 2 - Matched:', match['matched'])\n",
    "    print('         Missing:', match['missing'])\n",
    "    print('         Overall:', match['overall'])\n",
    "    print('STEP 3 - Score  :', scores['total'], '/100')\n",
    "    print('         Breakdown: skills=%d exp=%d tools=%d edu=10' % (scores['skill_pts'], scores['exp_pts'], scores['tool_pts']))\n",
    "    print('STEP 4 - LLM    :', explanation.strip())\n",
    "    print('RESULT  -->', rec)\n",
    "    print()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "for c in RESUMES:\n",
    "    run_pipeline(c)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Debug run - edge case for LangSmith screenshot\n",
    "print('===== DEBUG RUN =====')\n",
    "run_pipeline({'name': 'Debug (Empty Resume)', 'text': 'No information provided.'})"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## After Running\n",
    "1. Go to **smith.langchain.com** -> Project **AI-Resume-Screener**\n",
    "2. You will see 4 runs - take a screenshot for submission\n",
    "\n",
    "Expected scores:\n",
    "- Alice (Strong) -> 85/100 -> HIRE\n",
    "- Ben (Average)  -> 45/100 -> CONSIDER\n",
    "- Carlos (Weak)  -> 10/100 -> REJECT"
   ]
  }
 ]
}
